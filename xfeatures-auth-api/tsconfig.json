{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"lib": ["ESNext"],
		"types": [
			"@cloudflare/workers-types",
			"@cloudflare/vitest-pool-workers"
		],
		"paths": {
			"@/*": ["./src/*"]
		},
		"strict": true,
		"skipLibCheck": true,
		"isolatedModules": true
	},
	"include": [
		"src/**/*.ts",
		"tests/**/*.ts",
		"vitest.config.ts",
		"worker-configuration.d.ts"
	],
	"exclude": ["node_modules"]
}
