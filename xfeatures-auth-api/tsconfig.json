{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"lib": ["ESNext"],
		"types": [
			"@cloudflare/workers-types/2026-03-01",
			"@cloudflare/vitest-pool-workers"
		],
		"paths": {
			"@/*": ["./src/*"]
		},
		"strict": true,
		"skipLibCheck": true,
		"isolatedModules": true
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.test.ts"
	],
	"exclude": ["node_modules"]
}
